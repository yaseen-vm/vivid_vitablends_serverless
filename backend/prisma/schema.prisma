generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id        String    @id @default(uuid())
  username  String    @unique
  password  String
  role      String    @default("admin")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions  Session[]
}

model Session {
  id               String   @id @default(uuid())
  adminId          String
  refreshTokenHash String   @unique
  expiresAt        DateTime
  deviceInfo       String?
  ipAddress        String?
  revoked          Boolean  @default(false)
  createdAt        DateTime @default(now())
  admin            Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([refreshTokenHash])
}

model Category {
  id           String    @id @default(cuid())
  name         String    @unique
  description  String?
  image        String?
  showOnHome   Boolean   @default(true)
  displayOrder Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  products     Product[]

  @@index([showOnHome, displayOrder])
}

model Product {
  id            String    @id @default(cuid())
  name          String
  description   String
  price         Float
  image         String
  categoryId    String
  category      Category  @relation(fields: [categoryId], references: [id])
  featured      Boolean   @default(false)
  badge         String?
  originalPrice Float?
  inStock       Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([categoryId])
  @@index([featured])
}

model Review {
  id         String   @id @default(cuid())
  name       String
  rating     Int
  comment    String
  showInHero Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([showInHero])
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model User {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  createdAt DateTime @default(now())
  orders    Order[]

  @@index([phone])
}

model Order {
  id           String      @id @default(cuid())
  orderId      String      @unique
  customerName String
  email        String
  phone        String
  address      String
  city         String
  state        String
  pincode      String
  total        Float
  status       String      @default("PENDING")
  whatsappSent Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  items        OrderItem[]

  @@index([orderId])
  @@index([status])
  @@index([userId])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  name      String
  quantity  Int
  price     Float
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}
