{
  "name": "@vivid/backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build": "npm run prisma:generate",
    "prisma:generate": "dotenv -e ../.env -- prisma generate",
    "prisma:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "prisma:studio": "dotenv -e ../.env -- prisma studio",
    "prepare": "husky || true",
    "lint-staged": "lint-staged",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.995.0",
    "@aws-sdk/s3-request-presigner": "^3.995.0",
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.21.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "redis": "^4.6.13",
    "sharp": "^0.34.5",
    "winston": "^3.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.2.5",
    "prisma": "^6.19.2"
  },
  "overrides": {
    "minimatch": "10.2.3",
    "tar": "7.5.10"
  },
  "resolutions": {
    "minimatch": "10.2.3",
    "tar": "7.5.10"
  }
}
