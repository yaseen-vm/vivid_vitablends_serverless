{
  "name": "@vivid/backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "wrangler dev",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "npm run prisma:generate",
    "prisma:generate": "dotenv -e ../.env -- prisma generate",
    "prisma:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "prisma:studio": "dotenv -e ../.env -- prisma studio",
    "prepare": "husky || true",
    "lint-staged": "lint-staged",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\""
  },
  "dependencies": {
    "@prisma/adapter-d1": "^7.5.0",
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.3.1",
    "hono": "^4.12.8",
    "jose": "^6.2.2",
    "loglevel": "^1.9.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "dotenv-cli": "^7.4.2",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.5",
    "prisma": "^6.19.2",
    "wrangler": "^4.76.0"
  },
  "overrides": {
    "minimatch": "10.2.3",
    "tar": "7.5.10"
  },
  "resolutions": {
    "minimatch": "10.2.3",
    "tar": "7.5.10"
  }
}
