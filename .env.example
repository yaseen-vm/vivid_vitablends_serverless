# Cloudflare Configuration
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token

# Backend Secrets (Set in Cloudflare Dashboard or Wrangler)
JWT_SECRET=your_secure_jwt_secret
JWT_REFRESH_SECRET=your_secure_jwt_refresh_secret

# Frontend Configuration
VITE_API_BASE_URL=https://vivid-vitablends-backend.your-subdomain.workers.dev
VITE_WHATSAPP_NUMBER=91XXXXXXXXXX

# Infrastructure (Terraform)
TF_VAR_cloudflare_api_token=${CLOUDFLARE_API_TOKEN}
TF_VAR_cloudflare_account_id=${CLOUDFLARE_ACCOUNT_ID}
